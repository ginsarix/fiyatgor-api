    "@sentry/node": "^10.49.0",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "hono": "^4.12.14",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.9",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
